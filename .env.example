# ===========================================
# PDF-Master - Environment Variables Template
# ===========================================
# Copy this file to .env and fill in your API keys

# -------------------------------------------
# AI Provider API Keys (at least one required)
# -------------------------------------------
ANTHROPIC_API_KEY=      # Claude API Key
OPENAI_API_KEY=         # OpenAI API Key (also works for DeepSeek, Moonshot)
GOOGLE_API_KEY=         # Gemini API Key
DEEPSEEK_API_KEY=       # DeepSeek API Key
QWEN_API_KEY=           # Qwen (Alibaba) API Key
ZHIPU_API_KEY=          # Zhipu AI API Key
MOONSHOT_API_KEY=       # Moonshot API Key

# -------------------------------------------
# Ollama (Local LLM - No API Key Required)
# -------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# -------------------------------------------
# OCR Configuration
# -------------------------------------------
# Tesseract language packs: tesseract --list-langs
TESSERACT_LANG=eng+chi_sim

# -------------------------------------------
# Logging (Optional)
# -------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=

# -------------------------------------------
# Development (Optional)
# -------------------------------------------
DEBUG=false
